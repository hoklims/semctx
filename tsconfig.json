{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@semantic-context/core": ["./packages/core/src/index.ts"],
      "@semantic-context/ts-analyzer": ["./packages/ts-analyzer/src/index.ts"],
      "@semantic-context/repository-store": ["./packages/repository-store/src/index.ts"],
      "@semantic-context/context-engine": ["./packages/context-engine/src/index.ts"],
      "@semantic-context/cocoindex-adapter": ["./packages/cocoindex-adapter/src/index.ts"],
      "@semantic-context/mcp-server": ["./packages/mcp-server/src/index.ts"],
      "@semantic-context/test-fixtures": ["./packages/test-fixtures/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "examples"
  ]
}
