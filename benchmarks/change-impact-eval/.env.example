# change-impact-eval — environment configuration (copy to .env and edit, or export directly).
# No corpus is redistributed; you supply a private repository to evaluate against.

# REQUIRED — git repo of the private corpus to mine commits from (read-only access).
SEMCTX_BENCH_REPO_ROOT=/path/to/private-corpus

# OPTIONAL — a semctx-INDEXED COPY of the corpus (a copy, never the repo you edit).
# Default: ./.semctx-bench/workspace  (relative to where you run the scripts)
# Create it once:  cp -r "$SEMCTX_BENCH_REPO_ROOT" ./.semctx-bench/workspace && \
#   (cd ./.semctx-bench/workspace && bun ../../apps/cli/src/index.ts init && bun ../../apps/cli/src/index.ts index)
SEMCTX_BENCH_WORKDIR=./.semctx-bench/workspace

# OPTIONAL — where intermediate + result artifacts are written (regenerated; git-ignored).
# Default: benchmarks/change-impact-eval/output
SEMCTX_BENCH_OUTPUT_DIR=benchmarks/change-impact-eval/output
