{
  "name": "semantic-context-compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "semctx — a deterministic, local-first repository change-impact analyzer: computes the semantic blast radius of a git diff and enforces repository contracts and invariants (PASS/WARN/BLOCK). Not a code-search replacement (ADR 0005).",
  "license": "Apache-2.0",
  "author": "hoklims <hoklims@gmail.com>",
  "homepage": "https://github.com/hoklims/semctx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoklims/semctx.git"
  },
  "bugs": {
    "url": "https://github.com/hoklims/semctx/issues"
  },
  "keywords": [
    "change-impact",
    "verify",
    "invariants",
    "contracts",
    "ci-gate",
    "typescript",
    "bun"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "bun test packages apps plugins",
    "semctx": "bun apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
